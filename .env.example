# Copy to project root as `.env` and fill in values:
#   cp .env.example .env

# --- API ---
PORT=3001
NODE_ENV=development

# --- MongoDB ---
#
# IMPORTANT: Put your DATABASE NAME in the URI path before `?` (e.g. /test or /myapp).
#
# Local (Docker: docker compose up -d):
MONGODB_URI=mongodb://127.0.0.1:27017/test
#
# Atlas example (replace USER, PASS, CLUSTER host):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/test?retryWrites=true&w=majority
#
# If your URI has no database path (...mongodb.net/?appName=...), set:
# MONGODB_DB_NAME=test

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRATION=7d

# --- Email (optional for local dev; OTP flows log to console if SMTP fails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AdaptiveMind <noreply@example.com>

# --- CORS (comma-separated origins for the Vite app) ---
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000

# --- Rate limits (optional overrides) ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=20
